---
import RutubePlayer from './RutubePlayer.astro';

interface Props {
  title: string;
  date: string;
  speaker: string;
  embedId: string;
  coverImage: string | ImageMetadata;
  delay?: number;
}

const { title, date, speaker, embedId, coverImage, delay = 0 } = Astro.props;
---

<div class="group fade-up" style={delay ? `transition-delay: ${delay}ms` : undefined}>
  <RutubePlayer embedId={embedId} coverImage={coverImage} title={title} />
  <h3 class="text-2xl font-serif mb-2 mt-6 group-hover:text-gold transition-colors duration-300">{title}</h3>
  <p class="text-xs font-medium uppercase tracking-wider text-gray-400 mb-1">{date}</p>
  <p class="text-sm text-gray-600 font-medium">{speaker}</p>
</div>
