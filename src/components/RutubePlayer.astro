---
import { Image } from 'astro:assets';

interface Props {
  embedId: string;
  coverImage: string | ImageMetadata;
  title?: string;
}

const { embedId, coverImage, title = "Видео проповеди" } = Astro.props;
const embedUrl = `https://rutube.ru/play/embed/${embedId}/?autoPlay=1&rel=0`;

const isLocalCover = typeof coverImage !== 'string';
---

<div class="relative aspect-[4/3] overflow-hidden rounded-2xl bg-gray-200 cursor-pointer shadow-lg hover:shadow-2xl transition duration-500 border border-white/50 group rutube-player-container" data-embed-url={embedUrl}>
  <div class="video-preview absolute inset-0 z-10 bg-gray-200">
    {isLocalCover ? (
      <Image src={coverImage as ImageMetadata} alt={title} class="w-full h-full object-cover transform group-hover:scale-105 transition duration-700" />
    ) : (
      <img src={coverImage as string} alt={title} class="w-full h-full object-cover transform group-hover:scale-105 transition duration-700" />
    )}
    <div class="absolute inset-0 bg-dark/20 group-hover:bg-dark/10 transition"></div>
    <div class="absolute inset-0 flex items-center justify-center">
      <div class="w-16 h-16 bg-white/20 border border-white/50 rounded-full flex items-center justify-center backdrop-blur-md group-hover:bg-white group-hover:scale-110 transition duration-300">
        <i data-feather="play" class="text-white group-hover:text-gold fill-current ml-1 w-6 h-6 transition"></i>
      </div>
    </div>
  </div>
  <div class="video-player hidden absolute inset-0 bg-black z-20">
    <!-- iframe will be dynamically created here on click -->
  </div>
</div>

<script>
  function initVideoPlayers() {
    document.querySelectorAll('.rutube-player-container').forEach(container => {
      if (container.getAttribute('data-player-init')) return;
      container.setAttribute('data-player-init', 'true');

      container.addEventListener('click', () => {
        const preview = container.querySelector('.video-preview');
        const player = container.querySelector('.video-player');
        const embedUrl = container.getAttribute('data-embed-url');

        if (preview && player && embedUrl) {
          const iframe = document.createElement('iframe');
          iframe.className = "w-full h-full";
          iframe.src = embedUrl;
          iframe.frameBorder = "0";
          iframe.allow = "autoplay; encrypted-media";
          iframe.setAttribute('allowfullscreen', 'true');
          
          player.appendChild(iframe);
          preview.classList.add('hidden');
          player.classList.remove('hidden');
        }
      });
    });
  }

  document.addEventListener('astro:page-load', initVideoPlayers);
</script>
