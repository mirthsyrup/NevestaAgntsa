---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SermonCard from '../../components/SermonCard.astro';
import { getCollection } from 'astro:content';

const sermons = await getCollection('sermons');
---

<BaseLayout title="Проповеди — Церковь «Невеста Агнца»">
    <div class="pt-32 pb-24 px-6 bg-[#F9F7F2]">
        <div class="container mx-auto">
            <div class="text-center mb-16 fade-up">
                <span class="text-gold-dark font-medium text-xs uppercase tracking-[0.2em] mb-2 block">Служение слова</span>
                <h1 class="text-5xl md:text-6xl text-dark mb-4">Архив проповедей</h1>
                <p class="text-gray-500 max-w-lg mx-auto text-lg leading-relaxed">
                    *вставить текст*
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-10">
                {sermons.map((sermon, i) => (
                    <SermonCard
                        title={sermon.data.title}
                        date={sermon.data.date}
                        speaker={sermon.data.speaker}
                        embedId={sermon.data.embedId}
                        coverImage={sermon.data.coverImage}
                        delay={i * 100}
                    />
                ))}
            </div>
        </div>
    </div>
</BaseLayout>
