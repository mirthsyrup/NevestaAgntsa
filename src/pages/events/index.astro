---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EventCard from '../../components/EventCard.astro';
import { getCollection } from 'astro:content';

const events = await getCollection('events');
---

<BaseLayout title="Календарь событий — Церковь «Невеста Агнца»">
    <div class="pt-32 pb-24 px-6 bg-[#F9F7F2]">
        <div class="container mx-auto">
            <div class="text-center mb-16 fade-up">
                <span class="text-gold-dark font-medium text-xs uppercase tracking-[0.2em] mb-2 block">Календарь</span>
                <h1 class="text-5xl md:text-6xl text-dark mb-4">Ближайшие события</h1>
                <p class="text-gray-500 max-w-lg mx-auto text-lg leading-relaxed">
                    *вставить текст*
                </p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                {events.map((event, i) => (
                    <EventCard
                        day={event.data.day}
                        month={event.data.month}
                        title={event.data.title}
                        timeOrDate={event.data.timeOrDate}
                        location={event.data.location}
                        icon={event.data.icon}
                        delay={i * 100}
                    />
                ))}
            </div>
        </div>
    </div>
</BaseLayout>
