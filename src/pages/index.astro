---
import BaseLayout from '../layouts/BaseLayout.astro';
import SermonCard from '../components/SermonCard.astro';
import EventCard from '../components/EventCard.astro';
import { getCollection } from 'astro:content';

import heroBg from '../assets/images/hero-bg.jpg';
import quoteBg from '../assets/images/quote-parallax.png';

const sermons = await getCollection('sermons');
const events = await getCollection('events');

// Take first 3 for home page
const recentSermons = sermons.slice(0, 3);
const recentEvents = events.slice(0, 3);
---

<BaseLayout title="Церковь «Невеста Агнца»">
    <!-- Hero Section -->
    <div class="hero-bg relative h-screen min-h-[700px] flex items-center justify-center overflow-hidden bg-cover bg-center" style={`background-image: url('${heroBg.src}');`}>
        <div class="absolute inset-0 bg-dark/40 mix-blend-multiply"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[#F9F7F2]"></div>
        
        <div class="relative z-10 text-center px-4 max-w-5xl mx-auto mt-10 fade-up">
            <div class="mb-6 flex justify-center">
                <span class="py-1.5 px-5 border border-white/30 rounded-full text-white/90 text-[11px] font-medium uppercase tracking-[0.25em] backdrop-blur-sm bg-white/5">Христианская церковь</span>
            </div>
            <h1 class="text-white font-medium leading-[1.1] mb-8 drop-shadow-xl" style="font-size: clamp(3.5rem, 6vw, 7rem);">
                Невеста <br><span class="italic font-light text-gold-light">Агнца</span>
            </h1>
            <p class="text-white/90 text-lg md:text-xl font-normal mb-12 max-w-xl mx-auto leading-relaxed tracking-wide antialiased">
                ㅤ
            </p>
            <div class="flex flex-col sm:flex-row gap-5 justify-center items-center">
                <a href="#contact" id="btn-join" class="bg-paper text-dark hover:bg-white py-4 px-10 rounded-full text-sm font-medium uppercase tracking-widest transition duration-300 shadow-glow hover:shadow-[0_0_40px_rgba(255,255,255,0.6)]">
                    Присоединиться
                </a>
                <a href="/sermons" class="group flex items-center gap-2 text-white hover:text-gold-light transition duration-300 text-sm font-medium uppercase tracking-widest border-b border-transparent hover:border-gold-light pb-1">
                    <i data-feather="play-circle" class="w-5 h-5 transition-transform group-hover:scale-110"></i>
                    Смотреть проповеди
                </a>
            </div>
        </div>
        
        <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-bounce text-white/50">
            <i data-feather="arrow-down" class="w-6 h-6"></i>
        </div>
    </div>

    <!-- Content Wrapper -->
    <div class="bg-paper relative z-10">
        
        <!-- НАША МИССИЯ -->
        <section class="py-32 px-6 relative overflow-hidden">
            <div class="absolute top-0 right-0 w-1/2 h-full bg-gold/5 -skew-x-12 transform translate-x-1/3 z-0 pointer-events-none"></div>
            <div class="floating-orb w-96 h-96 bg-gold top-20 left-[-100px] opacity-10"></div>
            
            <div class="container mx-auto relative z-10">
                <div class="text-center mb-24 fade-up">
                    <div class="title-decoration mb-4">
                        <span class="text-gold-dark font-medium text-xs uppercase tracking-[0.2em]">О нас</span>
                    </div>
                    <h2 class="text-5xl md:text-6xl text-dark">Наша Миссия</h2>
                </div>

                <div class="flex flex-col lg:flex-row items-center gap-16">
                    <div class="w-full lg:w-1/2 fade-up">
                        <div class="relative group">
                            <div class="absolute -inset-4 border border-gold/20 rounded-t-full rounded-b-[10rem] z-0 transform rotate-2 transition duration-700 group-hover:rotate-0"></div>
                            <img src="/src/assets/images/about-community.jpg" alt="Community" class="relative z-10 w-full h-[500px] object-cover rounded-t-full rounded-b-[10rem] shadow-2xl transition duration-700">
                        </div>
                    </div>
                    <div class="w-full lg:w-1/2 fade-up lg:pl-10">
                        <h3 class="text-4xl mb-8 italic text-dark">Свет миру и соль земли</h3>
                        <div class="space-y-6 text-[#4a4a4a] font-normal text-lg leading-relaxed">
                            <p>
                                *вставить текст*
                            </p>
                            <p>
                                *вставить текст*
                            </p>
                        </div>
                        <div class="mt-10 flex items-center gap-4">
                            <img src="https://ui-avatars.com/api/?name=P+C&background=A67B5B&color=fff" alt="Pastor" class="w-14 h-14 rounded-full border-2 border-white shadow-md">
                            <div>
                                <p class="font-serif text-xl italic text-dark">*вставить текст*</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ВЕРОУЧЕНИЕ -->
        <section id="beliefs" class="py-32 px-6 relative overflow-hidden">
            <div class="absolute inset-0 pattern-grid opacity-30 pointer-events-none"></div>
            <div class="floating-orb w-[600px] h-[600px] bg-gold-light bottom-[-200px] right-[-200px] opacity-5"></div>

            <div class="container mx-auto relative z-10">
                <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
                    <!-- Item 1 -->
                    <div class="glass-card rounded-[2.5rem] p-10 hover:-translate-y-2 transition duration-500 group flex flex-col items-center text-center fade-up">
                        <div class="mb-6 p-4 rounded-full bg-white/50 text-gold group-hover:bg-gold group-hover:text-white transition duration-500 shadow-sm">
                            <i data-feather="book-open" class="w-8 h-8"></i>
                        </div>
                        <h3 class="text-2xl mb-4 font-serif text-dark">Библия</h3>
                        <p class="text-gray-600 font-normal leading-relaxed text-sm">
                            *вставить текст*
                        </p>
                    </div>
                    <!-- Item 2 -->
                    <div class="glass-card rounded-[2.5rem] p-10 hover:-translate-y-2 transition duration-500 group flex flex-col items-center text-center fade-up" style="transition-delay: 100ms;">
                        <div class="mb-6 p-4 rounded-full bg-white/50 text-gold group-hover:bg-gold group-hover:text-white transition duration-500 shadow-sm">
                            <i data-feather="heart" class="w-8 h-8"></i>
                        </div>
                        <h3 class="text-2xl mb-4 font-serif text-dark">Бог</h3>
                        <p class="text-gray-600 font-normal leading-relaxed text-sm">
                            *вставить текст*
                        </p>
                    </div>
                    <!-- Item 3 -->
                    <div class="glass-card rounded-[2.5rem] p-10 hover:-translate-y-2 transition duration-500 group flex flex-col items-center text-center fade-up" style="transition-delay: 200ms;">
                        <div class="mb-6 p-4 rounded-full bg-white/50 text-gold group-hover:bg-gold group-hover:text-white transition duration-500 shadow-sm">
                            <i data-feather="users" class="w-8 h-8"></i>
                        </div>
                        <h3 class="text-2xl mb-4 font-serif text-dark">Церковь</h3>
                        <p class="text-gray-600 font-normal leading-relaxed text-sm">
                            *вставить текст*
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Цитата Параллакс -->
        <div class="parallax-section relative h-[60vh] flex items-center justify-center bg-fixed bg-cover bg-center overflow-hidden" style={`background-image: url('${quoteBg.src}');`}>
            <div class="absolute inset-0 bg-black/40"></div>
            <div class="container mx-auto px-6 relative z-10 text-center text-white fade-up">
                <div class="w-16 h-16 mx-auto mb-8 rounded-full border border-white/20 flex items-center justify-center bg-white/5 backdrop-blur-md">
                    <i data-feather="message-circle" class="w-8 h-8 text-white/80"></i>
                </div>
                <h2 class="text-4xl md:text-7xl font-serif italic mb-8 leading-tight drop-shadow-lg">"…пойди, я покажу тебе жену,<br>невесту Агнца"</h2>
                <span class="inline-block border-t border-white/40 pt-4 text-sm uppercase tracking-[0.3em] font-medium">Откровение 21:9</span>
            </div>
        </div>

        <!-- ПРОПОВЕДИ -->
        <section id="sermons" class="py-32 px-6 relative overflow-hidden">
            <!-- Фоновый декор -->
            <div class="skew-bg top-20 bg-gold/5 h-1/2"></div>
            
            <div class="container mx-auto relative z-10">
                <div class="flex flex-col md:flex-row justify-between items-end mb-16 gap-6 fade-up">
                    <div>
                        <span class="text-gold-dark font-medium text-xs uppercase tracking-[0.2em] mb-2 block">Служение слова</span>
                        <h2 class="text-5xl text-dark">Проповеди</h2>
                    </div>
                    <a href="https://rutube.ru/channel/42730775/" target="_blank" class="group flex items-center gap-3 text-sm font-medium uppercase tracking-widest hover:text-gold transition">
                        Все видео <i data-feather="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition"></i>
                    </a>
                </div>

                <div class="grid md:grid-cols-3 gap-10">
                    {recentSermons.map((sermon, i) => (
                        <SermonCard
                            title={sermon.data.title}
                            date={sermon.data.date}
                            speaker={sermon.data.speaker}
                            embedId={sermon.data.embedId}
                            coverImage={sermon.data.coverImage}
                            delay={i * 100}
                        />
                    ))}
                </div>
            </div>
        </section>

        <!-- БЛИЖАЙШИЕ СОБЫТИЯ -->
        <section id="events" class="py-32 px-6 relative overflow-hidden">
            <div class="absolute left-0 top-1/3 w-full h-96 bg-gradient-to-r from-gold/5 via-transparent to-transparent -skew-y-3 pointer-events-none"></div>
            <div class="floating-orb w-64 h-64 bg-gold top-20 right-20 opacity-10"></div>
            
            <div class="container mx-auto relative z-10">
                <div class="text-center mb-20 fade-up">
                    <div class="title-decoration mb-4">
                        <span class="text-gold-dark font-medium text-xs uppercase tracking-[0.2em]">Календарь</span>
                    </div>
                    <h2 class="text-5xl text-dark">Ближайшие события</h2>
                </div>

                <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {recentEvents.map((event, i) => (
                        <EventCard
                            day={event.data.day}
                            month={event.data.month}
                            title={event.data.title}
                            timeOrDate={event.data.timeOrDate}
                            location={event.data.location}
                            icon={event.data.icon}
                            delay={i * 100}
                        />
                    ))}
                </div>
                
                <div class="flex justify-center mt-16 fade-up">
                    <a href="/events" class="inline-flex items-center justify-center py-4 px-10 border border-gold/40 hover:border-gold hover:bg-gold hover:text-white rounded-full text-xs font-bold uppercase tracking-widest transition-all duration-300">
                        Посмотреть весь календарь
                    </a>
                </div>
            </div>
        </section>
    </div>
</BaseLayout>

<script>
    import { playNobleSound } from '../scripts/audio';

    // Параллакс-эффект на скролл для Hero и цитаты + привязка звука
    document.addEventListener('astro:page-load', () => {
        const heroEl = document.querySelector('.hero-bg') as HTMLElement;
        const parallaxEl = document.querySelector('.parallax-section') as HTMLElement;
        const btnJoin = document.getElementById('btn-join');
        const isMobile = () => window.innerWidth <= 768;
        let lastPlay = 0;

        function updateParallax() {
            if (isMobile()) return;
            const scrollY = window.scrollY;
            if (heroEl) {
                heroEl.style.backgroundPositionY = `calc(50% + ${scrollY * 0.4}px)`;
            }
            if (parallaxEl) {
                const rect = parallaxEl.getBoundingClientRect();
                const offset = (rect.top + rect.height / 2 - window.innerHeight / 2) * 0.3;
                parallaxEl.style.backgroundPositionY = `calc(50% + ${offset}px)`;
            }
        }

        if (heroEl || parallaxEl) {
            window.addEventListener('scroll', updateParallax, { passive: true });
            updateParallax();
        }

        function handleJoinClick() {
            const now = Date.now();
            if (now - lastPlay >= 1000) {
                playNobleSound();
                lastPlay = now;
            }
        }
        btnJoin?.addEventListener('click', handleJoinClick);

        // Очищаем слушатели перед переходом на другую страницу
        document.addEventListener('astro:before-swap', () => {
            window.removeEventListener('scroll', updateParallax);
            btnJoin?.removeEventListener('click', handleJoinClick);
        }, { once: true });
    });
</script>
